# Frontend running port
VITE_FRONTEND_PORT=5173

# Use /api in local dev with Vite proxy. For cloud deployment, set full backend URL.
VITE_API_BASE_URL=/api

# Enable or disable Vite dev proxy
VITE_DEV_PROXY=true

# Proxy target used only when VITE_DEV_PROXY=true
VITE_BACKEND_TARGET=http://127.0.0.1:8080

# Axios timeout (ms)
VITE_HTTP_TIMEOUT=10000
