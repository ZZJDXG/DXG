<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--map是强大映射 type是简单映射-->
<mapper namespace="cn.yonyong.dao.DepartmentDao">

    <resultMap type="cn.yonyong.pojo.Department" id="DepartmentsMap">
        <result property="departmentID" column="DeptID" jdbcType="INTEGER"/>
        <result property="departmentName" column="DeptName" jdbcType="VARCHAR"/>
        <result property="supportChannels" column="SupportChannels" jdbcType="VARCHAR"/>
        <result property="superiordept" column="SuperiorDept" jdbcType="INTEGER"/>
        <result property="shifttype" column="ShiftType" jdbcType="INTEGER"/>
        <result property="attendanceday" column="AttendanceDay" jdbcType="VARCHAR"/>
        <result property="attendancerule1start" column="AttendanceRule1Start" jdbcType="VARCHAR"/>
        <result property="attendancerule1end" column="AttendanceRule1End" jdbcType="VARCHAR"/>
        <result property="attendancerule2start" column="AttendanceRule2Start" jdbcType="VARCHAR"/>
        <result property="attendancerule2end" column="AttendanceRule2End" jdbcType="VARCHAR"/>
        <result property="cleartime" column="ClearTime" jdbcType="VARCHAR"/>
    </resultMap>

    <!-- 获取菜单栏：返回 SupportChannels -->
    <select id="queryDepartmentById" resultType="java.lang.String">
        SELECT SupportChannels
        FROM departments
        WHERE DeptID = #{departmentID}
    </select>

    <!-- 查询全部部门：返回 List<Department> -->
    <select id="queryDepartments" resultMap="DepartmentsMap">
        SELECT
            DeptID, DeptName, SupportChannels, SuperiorDept, ShiftType, AttendanceDay, AttendanceRule1Start, AttendanceRule1End, AttendanceRule2Start, AttendanceRule2End, ClearTime
        FROM departments
        ORDER BY DeptID ASC
    </select>

    <!-- 新增部门 -->
    <insert id="insertDepartment"
            parameterType="cn.yonyong.pojo.Department"
            useGeneratedKeys="true"
            keyProperty="departmentID">
        INSERT INTO departments (DeptName, SupportChannels)
        VALUES (#{departmentName}, #{supportChannels})
    </insert>

    <!-- 查重：同名部门是否已存在（新增用） -->
    <select id="countByDeptName" resultType="int">
        SELECT COUNT(1)
        FROM departments
        WHERE DeptName = #{departmentName}
    </select>

    <!-- ✅ 查重：同名但排除当前ID（更新用） -->
    <select id="countByDeptNameExcludeId" resultType="int">
        <![CDATA[
            SELECT COUNT(1)
            FROM departments
            WHERE DeptName = #{departmentName}
            AND DeptID <> #{departmentID}
        ]]>
    </select>


    <!-- 删除部门 -->
    <delete id="deleteDepartmentById">
        DELETE FROM departments
        WHERE DeptID = #{departmentID}
    </delete>

    <!-- 更新部门信息 + 自动更新时间 -->
    <update id="updateDepartment" parameterType="cn.yonyong.pojo.Department">
        UPDATE departments
        SET
            DeptName = #{departmentName},
            SupportChannels = #{supportChannels}
        WHERE DeptID = #{departmentID}
    </update>

</mapper>
